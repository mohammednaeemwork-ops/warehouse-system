{
  "name": "warehouse-system",
  "version": "1.0.6",
  "description": "نظام إدارة المخازن - شركة العمار للتوسع العمراني",
  "main": "main.js",
  "author": "شركة العمار للتوسع العمراني",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "electron-updater": "^6.3.4"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.alammar.warehouse",
    "productName": "نظام المخازن مجموعة شركات العمار",
    "files": [
      "main.js",
      "index.html",
      "icon.png",
      "icon.ico"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "mohammednaeemwork-ops",
        "repo": "warehouse-system"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "نظام المخازن"
    }
  }
}